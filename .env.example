# Copy this file to .env, then replace every secret before starting the service.

# Required. Create this in the Resend dashboard.
RESEND_API_KEY=re_replace_me

# Required. Use the Resend webhook signing secret for the inbound webhook.
RESEND_WEBHOOK_SECRET=whsec_replace_me

# Required. Shared secret for local /send requests from resend_mcp_server.py.
# Generate your own value with: openssl rand -hex 32
RESEND_BRIDGE_SEND_SECRET=change-me-generate-with-openssl-rand-hex-32

# Required. Verified Resend sender domain, without @.
RESEND_DOMAIN=example.com

# Required. Local part for inbound bot mail, for example bot@example.com.
BOT_FROM_LOCAL=bot

# Required. Local part for owner/manual outgoing mail, for example mail@example.com.
OWNER_FROM_LOCAL=mail

# Required. Display name used in notices to the owner.
AI_NAME=Hermes

# Optional. Bridge URL used by the MCP server.
RESEND_BRIDGE_URL=http://127.0.0.1:8765

# Optional. Default manual sender local part; defaults to OWNER_FROM_LOCAL.
RESEND_DEFAULT_FROM_LOCAL=mail

# Optional. Only set when hermes is not on PATH, ~/.local/bin, or /usr/local/bin.
# HERMES_SEND_BIN=/home/your-user/.local/bin/hermes

# Optional. Hermes config directory containing config.yaml.
# Defaults to ~/.hermes.
# HERMES_HOME=/home/your-user/.hermes

# Optional. Host Hermes proxy base URL. The bridge derives /task and /send
# from this base URL.
# HERMES_PROXY_URL=http://127.0.0.1:18765

# Optional. Shared secret for the Hermes host proxy. Defaults to
# RESEND_BRIDGE_SEND_SECRET in the bridge container.
# HERMES_PROXY_SECRET=change-me-generate-with-openssl-rand-hex-32

# Optional Docker path mapping. Set these when the bridge runs in a container
# and host Hermes needs host-readable attachment/cache paths.
# BRIDGE_HOST_DATA_DIR=/home/your-user/resend-hermes-bridge/data
# HERMES_HOST_HOME=/home/your-user/.hermes

# Optional. Notification target passed to `hermes send --to`.
# Hermes supports telegram, weixin, qqbot, wecom, discord, slack, signal, etc.
# Platform credentials are configured in Hermes (~/.hermes/.env), not here.
NOTIFICATION_TARGET=telegram

# Optional. Python logging level for the bridge process.
LOG_LEVEL=INFO

# Optional. User-Agent sent to Resend and attachment download URLs.
BRIDGE_USER_AGENT=resend-hermes-bridge/1.0

# Optional. Local directory for temporary authorized bot auto-reply context.
# Defaults to ./bot_reply_contexts in this repository.
# BOT_REPLY_CONTEXT_DIR=/home/your-user/resend-hermes-bridge/bot_reply_contexts

# Optional. Runtime limits and retention policy.
MAX_ATTACHMENT_DOWNLOAD_BYTES=15728640
MAX_OUTBOUND_ATTACHMENT_BYTES=31457280
HERMES_TIMEOUT_SECONDS=180
BRIDGE_RETENTION_DAYS=90
BRIDGE_RECOVER_FAILED_EVENTS=true
BRIDGE_EVENT_RECOVERY_LIMIT=50
RESEND_MCP_DRAFT_TTL_SECONDS=604800

# Optional. Colon-separated roots where Hermes may save generated attachments.
# Defaults to ~/.hermes/cache.
# GENERATED_ATTACHMENT_ROOTS=/home/your-user/.hermes/cache
