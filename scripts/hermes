#!/usr/bin/env python3
"""Container-side wrapper for the host Hermes `send` command.

Talks to a tiny proxy running on the host. The default Docker deployment uses
host networking, so loopback reaches the host proxy.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request


PROXY_URL = os.getenv("HERMES_PROXY_URL", "http://127.0.0.1:18765").rstrip("/")
SECRET = os.getenv("HERMES_PROXY_SECRET") or os.getenv("RESEND_BRIDGE_SEND_SECRET", "")


def fail(message: str, code: int = 1) -> None:
    print(message, file=sys.stderr)
    sys.exit(code)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="hermes",
        description="Forward hermes send to the host proxy.",
        usage="hermes send --to TARGET [options] [message]",
    )
    subparsers = parser.add_subparsers(dest="command")
    send_parser = subparsers.add_parser("send", help="Send a message")
    send_parser.add_argument("-t", "--to", required=True, dest="target")
    send_parser.add_argument("-s", "--subject", default="")
    send_parser.add_argument("-f", "--file", default="")
    send_parser.add_argument("-q", "--quiet", action="store_true")
    send_parser.add_argument("--json", action="store_true", dest="json_output")
    send_parser.add_argument("message", nargs="?")

    args = parser.parse_args(argv)

    if args.command != "send":
        parser.print_help(sys.stderr)
        return 2

    message = args.message or ""
    if args.file and args.file != "-":
        try:
            with open(args.file, "r", encoding="utf-8") as fh:
                message = fh.read()
        except OSError as exc:
            fail(f"Cannot read file {args.file}: {exc}")
    elif not message:
        message = sys.stdin.read()

    payload = {
        "target": args.target,
        "message": message,
        "subject": args.subject,
        "quiet": args.quiet,
        "json": args.json_output,
    }

    req = urllib.request.Request(
        f"{PROXY_URL}/send",
        data=json.dumps(payload, ensure_ascii=False).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    if SECRET:
        req.add_header("Authorization", f"Bearer {SECRET}")

    try:
        with urllib.request.urlopen(req, timeout=90) as resp:
            body = json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        try:
            detail = exc.read().decode("utf-8")
        except Exception:
            detail = ""
        fail(f"hermes send proxy error ({exc.code}): {detail}")
    except Exception as exc:
        fail(f"hermes send proxy unreachable: {exc}")

    sys.stdout.write(body.get("stdout", ""))
    sys.stderr.write(body.get("stderr", ""))
    return body.get("returncode", 1)


if __name__ == "__main__":
    sys.exit(main())
